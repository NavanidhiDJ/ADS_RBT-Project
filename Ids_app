    return render_template_string(HTML_TEMPLATE)

@app.route("/api/inject", methods=["POST"])
def inject():
    data = request.json or {}
    ttype_name = data.get("type")
    ttype = next((t for t in THREAT_TYPES if t["type"] == ttype_name), None)
    threat = make_threat(ttype)
    threat_registry[threat["id"]] = threat
    threat_counter[0] += 1

    primary_tree.insert(threat["severity"], threat)
    okasaki_tree.insert(threat["severity"], threat)

    inv = verify_invariants(primary_tree.root)
    sc_pct = round((primary_tree.short_circuits / max(primary_tree.balance_calls,1)) * 100, 1)

    add_log(
        f"🔴 THREAT [{threat['type']}] P:{threat['severity']} from {threat['source_ip']} | SC:{sc_pct}%",
        threat["color"], "ALERT"
    )
    return jsonify({
        "threat": threat,
        "tree": primary_tree.root.to_dict() if primary_tree.root else None,
        "okasaki_tree": okasaki_tree.root.to_dict() if okasaki_tree.root else None,
        "stats": get_stats(),
        "invariant": inv,
    })

@app.route("/api/resolve", methods=["POST"])
def resolve():
    data = request.json or {}
    tid = data.get("id")
    threat = threat_registry.get(tid)
    if not threat:
        return jsonify({"error": "Threat not found"}), 404

    primary_tree.delete(threat["severity"])
    okasaki_tree.delete(threat["severity"])
    threat["status"] = "RESOLVED"
    resolved_log.insert(0, {**threat, "resolvedAt": time.time()})
    if len(resolved_log) > 30: resolved_log.pop()
    del threat_registry[tid]

    add_log(f"✅ RESOLVED [{threat['type']}] P:{threat['severity']} | {tid}", "#30d158", "RESOLVED")
    return jsonify({
        "tree": primary_tree.root.to_dict() if primary_tree.root else None,
        "okasaki_tree": okasaki_tree.root.to_dict() if okasaki_tree.root else None,
        "stats": get_stats(),
    })

@app.route("/api/serve_critical", methods=["POST"])
def serve_critical():
    """Serve the highest severity threat"""
    if not primary_tree.root: return jsonify({"threat": None, "stats": get_stats()})
    node = primary_tree.root
    while node.right: node = node.right
    threat = node.value
    if threat:
        primary_tree.delete(threat["severity"])
        okasaki_tree.delete(threat["severity"])
        threat["status"] = "MITIGATED"
        resolved_log.insert(0, {**threat, "resolvedAt": time.time()})
        if len(resolved_log) > 30: resolved_log.pop()
        if threat["id"] in threat_registry: del threat_registry[threat["id"]]
        add_log(f"🛡️ MITIGATED CRITICAL [{threat['type']}] P:{threat['severity']}", "#0a84ff", "MITIGATED")
    return jsonify({
        "threat": threat,
        "tree": primary_tree.root.to_dict() if primary_tree.root else None,
        "stats": get_stats(),
    })

@app.route("/api/benchmark", methods=["POST"])
def benchmark():
    data = request.json or {}
    n = min(int(data.get("n", 500)), 2000)
    order = data.get("order", "random")

    keys = list(range(1, n+1))
    if order == "random": random.shuffle(keys)
    elif order == "descending": keys = list(reversed(keys))

    results = {}
    trees = [
        ("Monadic (Moy)", MonadicTree()),
        ("Okasaki", OkasakiTree()),
        ("Germane-Might", GermaneMightTree(corrected=False)),
        ("Germane-Might (Fixed)", GermaneMightTree(corrected=True)),
    ]

    for name, tree in trees:
        tracemalloc.start()
        t0 = time.perf_counter()
        for k in keys:
            tree.insert(k, {"severity": k, "type": "BENCH"})
        insert_time = (time.perf_counter() - t0) * 1000

        t1 = time.perf_counter()
        del_keys = keys[:n//2]
        for k in del_keys:
            tree.delete(k)
        delete_time = (time.perf_counter() - t1) * 1000

        _, mem_peak = tracemalloc.get_traced_memory()
        tracemalloc.stop()

        inv = verify_invariants(tree.root)
        sc_pct = round((getattr(tree,'short_circuits',0) / max(getattr(tree,'balance_calls',1),1)) * 100, 1)

        results[name] = {
            "insert_ms":      round(insert_time, 2),
            "delete_ms":      round(delete_time, 2),
            "total_ms":       round(insert_time + delete_time, 2),
            "rotations":      getattr(tree, 'rotations', 0),
            "balance_calls":  getattr(tree, 'balance_calls', 0),
            "short_circuits": getattr(tree, 'short_circuits', 0),
            "sc_percent":     sc_pct,
            "memory_kb":      round(mem_peak / 1024, 1),
            "invariant_valid":inv["valid"],
            "tree_height":    inv["tree_height"],
            "black_height":   inv["black_height"],
            "n": n, "order": order,
        }

    # Calculate speedups vs Okasaki
    ok_ins = results["Okasaki"]["insert_ms"]
    ok_del = results["Okasaki"]["delete_ms"]
    for name in results:
        if name != "Okasaki":
            results[name]["insert_speedup"] = round(ok_ins / max(results[name]["insert_ms"], 0.001), 2)
            results[name]["delete_speedup"] = round(ok_del / max(results[name]["delete_ms"], 0.001), 2)

    benchmark_results.update(results)
    add_log(f"📊 BENCHMARK n={n} [{order}] — Monadic {results['Monadic (Moy)']['insert_speedup'] if 'insert_speedup' in results.get('Monadic (Moy)',{}) else '?'}× faster", "#5e5ce6", "BENCH")
    return jsonify(results)

@app.route("/api/verify", methods=["GET"])

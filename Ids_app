# INVARIANT VERIFIER
# ═══════════════════════════════════════════════════════════════

def verify_invariants(root):
    violations = []

    def check_red_child(node, parent_red=False):
        if node is None: return
        if parent_red and is_red(node):
            violations.append(f"RED-CHILD VIOLATION at key={node.key}")
        check_red_child(node.left, is_red(node))
        check_red_child(node.right, is_red(node))

    def check_black_height(node):
        if node is None: return 0
        lbh = check_black_height(node.left)
        rbh = check_black_height(node.right)
        if lbh != rbh:
            violations.append(f"BLACK-HEIGHT VIOLATION at key={node.key}: left={lbh}, right={rbh}")
        return lbh + (1 if is_black(node) else 0)

    def get_height(node):
        if node is None: return 0
        return 1 + max(get_height(node.left), get_height(node.right))

    def get_black_height(node):
        if node is None: return 0
        return get_black_height(node.left) + (1 if is_black(node) else 0)

    check_red_child(root)
    check_black_height(root)
    height = get_height(root)
    bh = get_black_height(root)

    return {
        "valid": len(violations) == 0,
        "violations": violations,
        "tree_height": height,
        "black_height": bh,
        "red_child_ok": not any("RED-CHILD" in v for v in violations),
        "black_height_ok": not any("BLACK-HEIGHT" in v for v in violations),
    }


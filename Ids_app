# ALGORITHM 2: MOY MONADIC (Section 3 of paper)
# ═══════════════════════════════════════════════════════════════

class MonadicTree:
    name = "Monadic (Moy)"

    def __init__(self):
        self.root = None
        self.rotations = 0
        self.balance_calls = 0
        self.short_circuits = 0
        self.todo_calls = 0

    def _done(self, tree): return (False, tree)
    def _todo(self, tree): return (True,  tree)

    def _fmap(self, f, result):
        is_todo, tree = result
        return (is_todo, f(tree))

    def _bind(self, result, f):
        is_todo, tree = result
        if not is_todo:
            self.short_circuits += 1
            return result
        return f(tree)

    def _balance(self, color, left, key, value, right):
        self.balance_calls += 1
        n = mk(color, left, key, value, right)
        if color==BLACK and is_red(left) and left and is_red(left.left):
            a,x,vx = left.left.left, left.left.key, left.left.value
            b,y,vy = left.left.right, left.key, left.value
            c,z,vz = left.right, key, value
            d = right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if color==BLACK and is_red(left) and left and is_red(left.right):
            a,x,vx = left.left, left.key, left.value
            b,y,vy = left.right.left, left.right.key, left.right.value
            c,z,vz = left.right.right, key, value
            d = right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if color==BLACK and is_red(right) and right and is_red(right.left):
            a,x,vx = left, key, value
            b,y,vy = right.left.left, right.left.key, right.left.value
            c,z,vz = right.left.right, right.key, right.value
            d = right.right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if color==BLACK and is_red(right) and right and is_red(right.right):
            a,x,vx = left, key, value
            b,y,vy = right.left, right.key, right.value
            c,z,vz = right.right.left, right.right.key, right.right.value
            d = right.right.right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if color == BLACK:
            self.short_circuits += 1
            return self._done(mk(BLACK, left, key, value, right))
        self.todo_calls += 1
        return self._todo(mk(RED, left, key, value, right))

    def _ins(self, node, key, value):
        if node is None:
            return self._todo(mk(RED, None, key, value, None))
        if key < node.key:
            result = self._ins(node.left, key, value)
            new_result = self._fmap(lambda a: mk(node.color, a, node.key, node.value, node.right), result)
            return self._bind(new_result, lambda t: self._balance(t.color, t.left, t.key, t.value, t.right))
        elif key > node.key:
            result = self._ins(node.right, key, value)
            new_result = self._fmap(lambda b: mk(node.color, node.left, node.key, node.value, b), result)
            return self._bind(new_result, lambda t: self._balance(t.color, t.left, t.key, t.value, t.right))
        else:
            return self._done(node)

    def insert(self, key, value):
        _, r = self._ins(self.root, key, value)
        if r: self.root = mk(BLACK, r.left, r.key, r.value, r.right)
        else: self.root = r

    def _blacken_prime(self, node):
        if node and is_red(node):
            return self._done(mk(BLACK, node.left, node.key, node.value, node.right))
        return self._todo(node)

    def _balance_prime(self, node):
        self.balance_calls += 1
        if node is None: return self._blacken_prime(node)
        k, left, key, value, right = node.color, node.left, node.key, node.value, node.right
        if is_red(left) and left and is_red(left.left):
            a,x,vx = left.left.left, left.left.key, left.left.value
            b,y,vy = left.left.right, left.key, left.value
            c,z,vz = left.right, key, value
            d = right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if is_red(left) and left and is_red(left.right):
            a,x,vx = left.left, left.key, left.value
            b,y,vy = left.right.left, left.right.key, left.right.value
            c,z,vz = left.right.right, key, value
            d = right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if is_red(right) and right and is_red(right.left):
            a,x,vx = left, key, value
            b,y,vy = right.left.left, right.left.key, right.left.value
            c,z,vz = right.left.right, right.key, right.value
            d = right.right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if is_red(right) and right and is_red(right.right):
            a,x,vx = left, key, value
            b,y,vy = right.left, right.key, right.value
            c,z,vz = right.right.left, right.right.key, right.right.value
            d = right.right.right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        return self._blacken_prime(node)

    def _eqL(self, node):
        if node is None: return self._todo(node)
        k, a, x, vx, sib = node.color, node.left, node.key, node.value, node.right
        if sib is None: return self._todo(node)
        if sib.color == BLACK:
            new_sib = mk(RED, sib.left, sib.key, sib.value, sib.right)
            return self._balance_prime(mk(k, a, x, vx, new_sib))
        else:
            b, y, vy, c = sib.left, sib.key, sib.value, sib.right
            inner = mk(RED, a, x, vx, b)
            result = self._eqL(inner)
            return self._fmap(lambda new_a: mk(BLACK, new_a, y, vy, c), result)

    def _eqR(self, node):
        if node is None: return self._todo(node)
        k, sib, y, vy, c = node.color, node.left, node.key, node.value, node.right
        if sib is None: return self._todo(node)
        if sib.color == BLACK:
            new_sib = mk(RED, sib.left, sib.key, sib.value, sib.right)
            return self._balance_prime(mk(k, new_sib, y, vy, c))
        else:
            a, x, vx, b = sib.left, sib.key, sib.value, sib.right
            inner = mk(RED, b, y, vy, c)
            result = self._eqR(inner)
            return self._fmap(lambda new_b: mk(BLACK, a, x, vx, new_b), result)

    def _del_min(self, node):
        if node is None: return self._done(None), None
        if node.left is None:
            min_key, min_val = node.key, node.value
            if is_red(node): return self._done(node.right), (min_key, min_val)
            return self._blacken_prime(node.right), (min_key, min_val)
        result, min_kv = self._del_min(node.left)
        new_result = self._fmap(lambda a: mk(node.color, a, node.key, node.value, node.right), result)
        return self._bind(new_result, self._eqL), min_kv

    def _del_cur(self, node):
        if node is None: return self._done(None)
        if is_red(node) and node.right is None: return self._done(node.left)
        if not is_red(node) and node.right is None: return self._blacken_prime(node.left)
        b_result, min_kv = self._del_min(node.right)
        if min_kv is None: return self._done(node.left)
        min_key, min_val = min_kv
        new_result = self._fmap(lambda b: mk(node.color, node.left, min_key, min_val, b), b_result)
        return self._bind(new_result, self._eqR)

    def _del(self, node, key):
        if node is None: return self._done(None)
        if key < node.key:
            result = self._del(node.left, key)
            new_result = self._fmap(lambda a: mk(node.color, a, node.key, node.value, node.right), result)
            return self._bind(new_result, self._eqL)
        elif key > node.key:
            result = self._del(node.right, key)
            new_result = self._fmap(lambda b: mk(node.color, node.left, node.key, node.value, b), result)
            return self._bind(new_result, self._eqR)
        else:
            return self._del_cur(node)

    def delete(self, key):
        _, r = self._del(self.root, key)
        self.root = r
        if self.root: self.root.color = BLACK

    def search(self, key):
        n = self.root
        while n:
            if key == n.key: return n.value
            n = n.left if key < n.key else n.right
        return None

    def count(self):
        def _c(n): return 0 if n is None else 1 + _c(n.left) + _c(n.right)
        return _c(self.root)


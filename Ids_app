  if (cnt > 0) hdr.classList.add("pulse"); else hdr.classList.remove("pulse");
  // Invariants
  const rcOk = stats.redChildOk, bhOk = stats.blackHeightOk;
  document.getElementById("inv-rc").textContent = "RED-CHILD: " + (rcOk?"✓ OK":"✗ VIOLATED");
  document.getElementById("inv-bh").textContent = "BLACK-HEIGHT: " + (bhOk?"✓ OK":"✗ VIOLATED");
  document.getElementById("inv-rc-dot").style.background = rcOk ? "#00ff88" : "#ff2d55";
  document.getElementById("inv-bh-dot").style.background = bhOk ? "#00ff88" : "#ff2d55";
  document.getElementById("hdr-inv").textContent = "⬡ INVARIANTS: " + (rcOk&&bhOk?"✓ VALID":"✗ VIOLATED");
  document.getElementById("hdr-inv").style.color = (rcOk&&bhOk) ? "#00ff88" : "#ff2d55";
}

function updateLog(logs) {

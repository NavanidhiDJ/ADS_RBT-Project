# Primary tree (Monadic) for live operations
primary_tree = MonadicTree()
okasaki_tree = OkasakiTree()

activity_log = []
resolved_log = []
threat_registry = {}   # id -> threat dict
threat_counter = [0]
benchmark_results = {}

def add_log(msg, color="#94a3b8", level="INFO"):
    entry = {"msg": msg, "color": color, "level": level, "t": time.time()}
    activity_log.insert(0, entry)
    if len(activity_log) > 80: activity_log.pop()

def get_stats():
    inv = verify_invariants(primary_tree.root)
    return {
        "inQueue":        primary_tree.count(),
        "totalResolved":  len(resolved_log),
        "rotations":      primary_tree.rotations,
        "shortCircuits":  primary_tree.short_circuits,
        "balanceCalls":   primary_tree.balance_calls,
        "todoCount":      primary_tree.todo_calls,
        "invariantValid": inv["valid"],
        "treeHeight":     inv["tree_height"],
        "blackHeight":    inv["black_height"],
        "redChildOk":     inv["red_child_ok"],
        "blackHeightOk":  inv["black_height_ok"],
    }


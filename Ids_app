<script>
const THREAT_TYPES = [
  {type:"DDOS",       label:"DDoS Attack",       base_sev:95, color:"#dc2626"},
  {type:"RANSOMWARE", label:"Ransomware",         base_sev:92, color:"#b91c1c"},
  {type:"MALWARE",    label:"Malware Injection",  base_sev:85, color:"#ea580c"},
  {type:"BRUTEFORCE", label:"Brute Force",        base_sev:75, color:"#d97706"},
  {type:"SQLINJECT",  label:"SQL Injection",      base_sev:70, color:"#ca8a04"},
  {type:"PORTSCAN",   label:"Port Scan",          base_sev:55, color:"#16a34a"},
  {type:"PHISHING",   label:"Phishing",           base_sev:50, color:"#2563eb"},
  {type:"RECON",      label:"Reconnaissance",     base_sev:35, color:"#7c3aed"},
  {type:"ANOMALY",    label:"Anomaly Detected",   base_sev:20, color:"#6b7280"},
];

// Build threat type rows
const ttList = document.getElementById("threat-types-list");
THREAT_TYPES.forEach(t => {
  const row = document.createElement("div");
  row.className = "threat-type-row";
  row.innerHTML = `
    <span style="font-size:12px;color:#374151;font-family:'IBM Plex Mono',monospace">${t.label}</span>
    <div style="display:flex;align-items:center;gap:8px">
      <div class="sev-bar" style="width:${Math.round(t.base_sev * 0.45)}px;background:${t.color}"></div>
      <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:${t.color};min-width:18px;text-align:right">${t.base_sev}</span>
    </div>`;
  row.onclick = () => injectThreat(t.type);
  ttList.appendChild(row);
});

// ── TREE RENDERER ─────────────────────────────────────
function assignPos(node, counter={v:0}, depth=0) {
  if (!node) return null;
  const left = assignPos(node.left, counter, depth+1);
  const xPos = counter.v++;
  const right = assignPos(node.right, counter, depth+1);
  return {...node, xPos, depth, left, right};
}
function countNodes(n) { return !n ? 0 : 1 + countNodes(n.left) + countNodes(n.right); }
function getDepth(n)   { return !n ? 0 : 1 + Math.max(getDepth(n.left), getDepth(n.right)); }
function getMaxNode(n) { return !n ? null : n.right ? getMaxNode(n.right) : n; }

function renderTree(svgId, root, style="monadic") {
  const svg = document.getElementById(svgId);
  const NW=34, VGAP=52, HGAP=22;

  if (!root) {
    svg.setAttribute("height","100");
    svg.innerHTML = `<text font-family="IBM Plex Mono,monospace" font-size="11" fill="#d1d5db" x="50%" y="50" text-anchor="middle">Empty tree</text>`;
    return;
  }

  const pos = assignPos(root);
  const total = countNodes(root);
  const depth = getDepth(root);
  const W = Math.max(350, total*(NW+HGAP));
  const H = Math.max(90, depth*VGAP+50);

  svg.setAttribute("viewBox", `0 0 ${W} ${H}`);
  svg.setAttribute("height", Math.min(H, 160));
  const maxN = getMaxNode(root);

  let edges="", nodes="";

  function traverse(node) {
    if (!node) return;
    const cx = node.xPos*(NW+HGAP)+NW/2;
    const cy = node.depth*VGAP+NW/2+6;

    const drawEdge = child => {
      if (!child) return;
      const ccx = child.xPos*(NW+HGAP)+NW/2;
      const ccy = child.depth*VGAP+NW/2+6;
      const isR = child.color==="RED";
      edges += `<line x1="${cx}" y1="${cy+NW/2-1}" x2="${ccx}" y2="${ccy-NW/2+1}"
        stroke="${isR ? "#fca5a5" : "#d1d5db"}"
        stroke-width="${isR ? 1.5 : 1}"
        stroke-dasharray="${isR ? "" : "4,3"}"/>`;
    };
    drawEdge(node.left); drawEdge(node.right);

    const isMax = maxN && node.key === maxN.key;
    const isRed = node.color === "RED";

    // Colors
    const fill   = isRed  ? "#fef2f2" : (isMax ? "#1f2937" : "#f9fafb");
    const stroke = isRed  ? "#fca5a5" : (isMax ? "#1f2937" : "#d1d5db");
    const textC  = isRed  ? "#b91c1c" : (isMax ? "#ffffff"  : "#374151");
    const sw     = isMax || isRed ? 1.5 : 1;

    const typeStr = (node.value?.type || "").slice(0,3);
    nodes += `<g>
      <circle cx="${cx}" cy="${cy}" r="${NW/2}" fill="${fill}" stroke="${stroke}" stroke-width="${sw}"/>
      <text x="${cx}" y="${cy-2}" text-anchor="middle" fill="${textC}" font-size="9" font-weight="600" font-family="IBM Plex Mono,monospace">${node.key}</text>
      <text x="${cx}" y="${cy+8}" text-anchor="middle" fill="${isRed?"#ef4444":isMax?"#9ca3af":"#9ca3af"}" font-size="7" font-family="IBM Plex Mono,monospace">${typeStr}</text>
    </g>`;
    traverse(node.left); traverse(node.right);
  }
  traverse(pos);
  svg.innerHTML = edges + nodes;
}

// ── STATE UPDATES ─────────────────────────────────────
let activeThreats = {};

function updateStats(stats) {
  document.getElementById("s-queue").textContent  = stats.inQueue;
  document.getElementById("s-res").textContent    = stats.totalResolved;
  document.getElementById("s-height").textContent = stats.treeHeight;
  document.getElementById("s-bh").textContent     = stats.blackHeight;
  document.getElementById("m-sc").textContent     = stats.shortCircuits;
  document.getElementById("m-todo").textContent   = stats.todoCount;
  document.getElementById("m-bc").textContent     = stats.balanceCalls;
  document.getElementById("m-rot").textContent    = stats.rotations;

  const pct = stats.balanceCalls > 0
    ? Math.round((stats.shortCircuits / stats.balanceCalls) * 100) : 0;
  document.getElementById("m-pct").textContent = pct + "%";
  document.getElementById("m-bar").style.width = pct + "%";

  // Header badge
  const cnt = stats.inQueue;
  const hdrCount = document.getElementById("hdr-count");
  const threatDot = document.getElementById("threat-dot");
  hdrCount.innerHTML = `<span class="status-dot ${cnt>0?"dot-red dot-pulse":"dot-gray"}" id="threat-dot"></span> ${cnt} active threat${cnt!==1?"s":""}`;
  hdrCount.className = cnt>0 ? "badge badge-red" : "badge badge-gray";

  // Invariants
  const rcOk = stats.redChildOk, bhOk = stats.blackHeightOk;
  const both = rcOk && bhOk;
  const rcEl = document.getElementById("inv-rc");
  const bhEl = document.getElementById("inv-bh");
  rcEl.textContent = (rcOk ? "✓" : "✗") + " Red-child: " + (rcOk?"OK":"VIOLATED");
  rcEl.className = "inv-item " + (rcOk ? "inv-ok" : "inv-fail");
  bhEl.textContent = (bhOk ? "✓" : "✗") + " Black-height: " + (bhOk?"OK":"VIOLATED");
  bhEl.className = "inv-item " + (bhOk ? "inv-ok" : "inv-fail");

  const hdrInv = document.getElementById("hdr-inv");
  hdrInv.innerHTML = `<span class="status-dot ${both?"dot-green":"dot-red"}"></span> Invariants: ${both?"valid":"violated"}`;
  hdrInv.className = both ? "badge badge-green" : "badge badge-red";
}

function fmtTime(ts) {
  const d = new Date(ts * 1000);
  return d.toTimeString().slice(0,8);
}

function updateLog(logs) {
  if (!logs || !logs.length) return;
  const c = document.getElementById("log-scroll");
  document.getElementById("log-count").textContent = logs.length + " entries";
  c.innerHTML = logs.map((l, i) => `
    <div class="log-entry">
      <span class="log-time">${fmtTime(l.t)}</span>${l.msg}
    </div>`).join("");
}

function updateThreats(threats) {
  activeThreats = {};
  threats.forEach(t => activeThreats[t.id] = t);
  const c = document.getElementById("threats-list");
  document.getElementById("queue-count").textContent = threats.length + " in tree";
  if (!threats.length) {
    c.innerHTML = `<div class="empty-hint">No active threats.</div>`;
    return;
  }
  const sorted = [...threats].sort((a,b) => b.severity - a.severity);
  c.innerHTML = sorted.map((t, i) => `
    <div class="threat-item animate-in" style="border-left-color:${t.color};opacity:${Math.max(0.5,1-i*0.04)}">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <span class="threat-type-label" style="color:${t.color}">${t.type}</span>
        <span class="threat-severity">${t.severity}</span>
      </div>
      <div class="threat-meta">${t.source_ip} → ${t.target_ip}</div>
      <div class="threat-meta">:${t.port} ${t.protocol} · ${(t.confidence*100).toFixed(0)}% conf</div>
      <button class="resolve-btn" onclick="resolveThreat('${t.id}')">Resolve</button>
    </div>`).join("");
}

function updateResolved(resolved) {
  const c = document.getElementById("resolved-list");
  if (!resolved || !resolved.length) {
    c.innerHTML = `<div style="font-size:11px;color:var(--gray-300);font-family:var(--font-mono)">No resolved threats.</div>`;
    return;
  }
  c.innerHTML = resolved.slice(0,8).map((t, i) => `
    <div class="resolved-row" style="opacity:${Math.max(0.35,1-i*0.1)}">
      <span style="font-family:var(--font-mono);font-size:10px;color:var(--gray-500)">${t.label}</span>
      <span style="font-family:var(--font-mono);font-size:10px;color:${t.color}">P:${t.severity}</span>
    </div>`).join("");
}

// ── API ───────────────────────────────────────────────
async function injectThreat(type=null) {
  const res = await fetch("/api/inject", {
    method:"POST", headers:{"Content-Type":"application/json"},
    body: JSON.stringify({type})
  });
  const data = await res.json();
  renderTree("moy-svg", data.tree, "monadic");
  renderTree("ok-svg", data.okasaki_tree, "okasaki");
  updateStats(data.stats);
  fetchState();
}

async function resolveThreat(tid) {
  const res = await fetch("/api/resolve", {
    method:"POST", headers:{"Content-Type":"application/json"},
    body: JSON.stringify({id: tid})
  });
  const data = await res.json();
  renderTree("moy-svg", data.tree);
  renderTree("ok-svg", data.okasaki_tree);
  updateStats(data.stats);
  fetchState();
}

async function serveCritical() {
  const res = await fetch("/api/serve_critical", {method:"POST"});
  const data = await res.json();
  renderTree("moy-svg", data.tree);
  updateStats(data.stats);
  fetchState();
}

async function fetchState() {
  const res = await fetch("/api/state");
  const data = await res.json();
  renderTree("moy-svg", data.tree);
  renderTree("ok-svg", data.okasaki_tree);
  updateStats(data.stats);
  updateLog(data.log);
  updateThreats(data.threats);
  updateResolved(data.resolved);
}

async function resetAll() {
  await fetch("/api/reset", {method:"POST"});
  document.getElementById("bench-results").innerHTML =
    `<div style="grid-column:span 4;font-size:11px;color:var(--gray-300);font-family:var(--font-mono)">Run a benchmark to compare all four algorithms.</div>`;
  fetchState();
}

async function runBenchmark() {
  const n = document.getElementById("bench-n").value;
  const order = document.getElementById("bench-order").value;
  const status = document.getElementById("bench-status");
  const btn = document.getElementById("btn-bench");
  status.textContent = "Running…"; btn.disabled = true; btn.style.opacity = "0.6";
  try {
    const res = await fetch("/api/benchmark", {
      method:"POST", headers:{"Content-Type":"application/json"},
      body: JSON.stringify({n: parseInt(n), order})
    });
    const data = await res.json();
    renderBenchmark(data, n, order);
    status.textContent = "Done ✓";
    setTimeout(() => status.textContent = "", 3000);
  } catch(e) {
    status.textContent = "Error";
  }
  btn.disabled = false; btn.style.opacity = "";
  fetchState();
}

function renderBenchmark(data, n, order) {
  const algos = Object.keys(data);
  const container = document.getElementById("bench-results");
  container.innerHTML = algos.map(name => {
    const d = data[name];
    const isMoy = name.includes("Monadic");
    const speedup = d.insert_speedup;
    const scPct = d.sc_percent ? `${d.sc_percent}%` : null;
    return `<div class="bench-card ${isMoy?"featured":""}">
      <div class="bench-name">${name.replace(" (Moy)","").replace(" (Fixed)"," ✓")}</div>
      <div class="bench-main">${d.insert_ms}<span style="font-size:10px;color:var(--gray-400)">ms</span></div>
      <div class="bench-detail">insert n=${n}</div>
      <div class="bench-detail" style="margin-top:3px">del: ${d.delete_ms}ms · rot: ${d.rotations}</div>
      ${scPct ? `<div class="bench-detail" style="color:var(--gray-600);margin-top:2px">SC: ${scPct}</div>` : ""}

      <div style="font-size:9px;color:var(--muted)">ROT: ${d.rotations}</div>
      ${isMoy ? `<div style="font-size:9px;color:var(--green)">SC SAVINGS: ${scPct}</div>` : ""}
      ${d.insert_speedup ? `<div style="font-size:9px;color:${d.insert_speedup>=1?"var(--green)":"var(--red)"}">vs Okasaki: ${speedup}</div>` : ""}
      <div style="font-size:8px;color:${d.invariant_valid?"var(--green)":"var(--red)"};margin-top:3px">${d.invariant_valid?"✓ INVARIANTS OK":"✗ VIOLATED"}</div>
    </div>`;

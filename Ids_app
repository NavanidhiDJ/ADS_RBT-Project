# ALGORITHM 3: GERMANE-MIGHT (original + Appendix B corrected)
# Uses double-black color for deletion
# ═══════════════════════════════════════════════════════════════

class GermaneMightTree:
    name = "Germane-Might"

    def __init__(self, corrected=False):
        self.root = None
        self.rotations = 0
        self.balance_calls = 0
        self.corrected = corrected
        if corrected: self.name = "Germane-Might (Fixed)"

    def _balance(self, color, left, key, value, right):
        self.balance_calls += 1
        if color==BLACK and is_red(left) and left and is_red(left.left):
            self.rotations += 1
            return mk(RED, mk(BLACK,left.left.left,left.left.key,left.left.value,left.left.right),
                      left.key, left.value, mk(BLACK,left.right,key,value,right))
        if color==BLACK and is_red(left) and left and is_red(left.right):
            self.rotations += 1
            return mk(RED, mk(BLACK,left.left,left.key,left.value,left.right.left),
                      left.right.key, left.right.value, mk(BLACK,left.right.right,key,value,right))
        if color==BLACK and is_red(right) and right and is_red(right.left):
            self.rotations += 1
            return mk(RED, mk(BLACK,left,key,value,right.left.left),
                      right.left.key, right.left.value, mk(BLACK,right.left.right,right.key,right.value,right.right))
        if color==BLACK and is_red(right) and right and is_red(right.right):
            self.rotations += 1
            return mk(RED, mk(BLACK,left,key,value,right.left),
                      right.key, right.value, mk(BLACK,right.right.left,right.right.key,right.right.value,right.right.right))
        return mk(color, left, key, value, right)

    def _ins(self, node, key, value):
        if node is None: return mk(RED, None, key, value, None)
        if self.corrected:
            # Corrected: check common cases FIRST (Appendix B)
            if key < node.key:
                return self._balance(node.color, self._ins(node.left,key,value), node.key, node.value, node.right)
            elif key > node.key:
                return self._balance(node.color, node.left, node.key, node.value, self._ins(node.right,key,value))
            else: return node
        else:
            # Original: base cases checked first (suboptimal order)
            if node.left is None and node.right is None:
                if key < node.key: return self._balance(node.color, mk(RED,None,key,value,None), node.key, node.value, None)
                elif key > node.key: return self._balance(node.color, None, node.key, node.value, mk(RED,None,key,value,None))
                else: return node
            if key < node.key:
                return self._balance(node.color, self._ins(node.left,key,value), node.key, node.value, node.right)
            elif key > node.key:
                return self._balance(node.color, node.left, node.key, node.value, self._ins(node.right,key,value))
            else: return node

    def insert(self, key, value):
        r = self._ins(self.root, key, value)
        self.root = mk(BLACK, r.left, r.key, r.value, r.right)

    def delete(self, key):
        self.root = self._del(self.root, key)
        if self.root: self.root.color = BLACK

    def _del(self, node, key):
        if node is None: return None
        if key < node.key:
            return self._bubble(node.color, self._del(node.left,key), node.key, node.value, node.right)
        elif key > node.key:
            return self._bubble(node.color, node.left, node.key, node.value, self._del(node.right,key))
        else:
            if node.right is None: return node.left
            min_key, min_val = self._min_node(node.right)
            new_right = self._del(node.right, min_key)
            return self._bubble(node.color, node.left, min_key, min_val, new_right)

    def _min_node(self, node):
        while node.left: node = node.left
        return node.key, node.value

    def _bubble(self, color, left, key, value, right):
        return self._balance(color, left, key, value, right)

    def search(self, key):
        n = self.root
        while n:
            if key == n.key: return n.value
            n = n.left if key < n.key else n.right
        return None

    def count(self):
        def _c(n): return 0 if n is None else 1 + _c(n.left) + _c(n.right)
        return _c(self.root)


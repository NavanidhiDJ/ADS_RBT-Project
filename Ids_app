}

async function runBenchmark() {
  const n = document.getElementById("bench-n").value;
  const order = document.getElementById("bench-order").value;
  const status = document.getElementById("bench-status");
  const btn = document.getElementById("btn-bench");
  status.textContent = "RUNNING..."; btn.disabled = true;
  try {
    const res = await fetch("/api/benchmark", {
      method:"POST", headers:{"Content-Type":"application/json"},
      body: JSON.stringify({n: parseInt(n), order})
    });
    const data = await res.json();
    renderBenchmark(data, n, order);
    status.textContent = "✓ DONE";
  } catch(e) {
    status.textContent = "ERROR";
  }
  btn.disabled = false;
  fetchState();
}

function renderBenchmark(data, n, order) {
  const algos = Object.keys(data);
  const container = document.getElementById("bench-results");
  const monadicIns = data["Monadic (Moy)"]?.insert_ms || 1;
  container.innerHTML = algos.map(name => {
    const d = data[name];
    const isMoy = name.includes("Monadic");
    const speedup = d.insert_speedup ? `${d.insert_speedup}×` : "—";
    const scPct = d.sc_percent ? `${d.sc_percent}%` : "—";
    const border = isMoy ? "var(--green)" : name.includes("Fixed") ? "var(--cyan)" : "var(--border2)";
    return `<div class="bench-card" style="border-color:${border}">
      <div class="bench-name">${name.replace(" (Moy)","").replace(" (Fixed)","✓")}</div>
      <div class="bench-val" style="color:${isMoy?"var(--green)":"var(--text)"}">${d.insert_ms}ms</div>
      <div class="bench-sub">INSERT (n=${n}, ${order})</div>

THREAT_TYPES = [
    {"type": "DDOS",        "label": "DDoS Attack",         "base_sev": 95, "color": "#ff2d55"},
    {"type": "RANSOMWARE",  "label": "Ransomware",          "base_sev": 92, "color": "#ff3b30"},
    {"type": "MALWARE",     "label": "Malware Injection",   "base_sev": 85, "color": "#ff6b35"},
    {"type": "BRUTEFORCE",  "label": "Brute Force",         "base_sev": 75, "color": "#ff9f0a"},
    {"type": "SQLINJECT",   "label": "SQL Injection",       "base_sev": 70, "color": "#ffd60a"},
    {"type": "PORTSCAN",    "label": "Port Scan",           "base_sev": 55, "color": "#30d158"},
    {"type": "PHISHING",    "label": "Phishing",            "base_sev": 50, "color": "#0a84ff"},
    {"type": "RECON",       "label": "Reconnaissance",      "base_sev": 35, "color": "#5e5ce6"},
    {"type": "ANOMALY",     "label": "Anomaly Detected",    "base_sev": 20, "color": "#636366"},
]

def random_ip(): return f"{random.randint(1,255)}.{random.randint(0,255)}.{random.randint(0,255)}.{random.randint(1,254)}"

def make_threat(ttype=None):
    t = ttype or random.choice(THREAT_TYPES)
    jitter = random.randint(-8, 8)
    severity = max(1, min(99, t["base_sev"] + jitter))
    tid = str(uuid.uuid4())[:8].upper()
    return {
        "id": tid,
        "type": t["type"],
        "label": t["label"],
        "severity": severity,
        "color": t["color"],
        "source_ip": random_ip(),
        "target_ip": random_ip(),
        "timestamp": time.time(),
        "status": "ACTIVE",
        "protocol": random.choice(["TCP","UDP","ICMP","HTTP","HTTPS"]),
        "port": random.choice([22,80,443,3306,8080,445,1433,3389]),
        "confidence": round(random.uniform(0.65, 0.99), 2),
    }


// ── TREE RENDERER ──────────────────────────────────────────────
function assignPos(node, counter={v:0}, depth=0) {
  if (!node) return null;
  const left = assignPos(node.left, counter, depth+1);
  const xPos = counter.v++;
  const right = assignPos(node.right, counter, depth+1);
  return {...node, xPos, depth, left, right};
}
function countNodes(n) { return !n ? 0 : 1 + countNodes(n.left) + countNodes(n.right); }
function getDepth(n) { return !n ? 0 : 1 + Math.max(getDepth(n.left), getDepth(n.right)); }
function getMaxNode(n) { return !n ? null : n.right ? getMaxNode(n.right) : n; }

function renderTree(svgId, root, accentColor="#00ff88") {
  const svg = document.getElementById(svgId);
  const NW=40, VGAP=60, HGAP=28;
  if (!root) {
    svg.setAttribute("height","100");
    svg.innerHTML=`<text class="empty-msg" x="50%" y="50" text-anchor="middle">Empty tree</text>`;
    return;
  }
  const pos = assignPos(root);
  const total = countNodes(root);
  const depth = getDepth(root);
  const W = Math.max(400, total*(NW+HGAP));
  const H = Math.max(100, depth*VGAP+60);
  svg.setAttribute("viewBox",`0 0 ${W} ${H}`);
  svg.setAttribute("height", Math.min(H, 180));
  const maxN = getMaxNode(root);

  let edges="", nodes="";
  function traverse(node) {
    if (!node) return;
    const cx = node.xPos*(NW+HGAP)+NW/2;
    const cy = node.depth*VGAP+NW/2+8;
    const drawEdge = child => {
      if (!child) return;
      const ccx=child.xPos*(NW+HGAP)+NW/2, ccy=child.depth*VGAP+NW/2+8;
      const isR = child.color==="RED";
      edges+=`<line x1="${cx}" y1="${cy+NW/2}" x2="${ccx}" y2="${ccy-NW/2}"
        stroke="${isR?"#ff2d55":"#1a5c3f"}" stroke-width="${isR?2:1.5}"
        stroke-dasharray="${isR?"none":"5,3"}" opacity=".8"/>`;
    };
    drawEdge(node.left); drawEdge(node.right);
    const isMax = maxN && node.key===maxN.key;
    const fill = node.color==="RED" ? "#ff2d55" : "#0a1e18";
    const stroke = isMax ? "#ffd60a" : (node.color==="RED" ? "#ff2d55" : "#1a5c3f");
    const sw = isMax ? 2.5 : 1.5;
    const glow = node.color==="RED" ? "drop-shadow(0 0 6px #ff2d5566)" : isMax ? "drop-shadow(0 0 8px #ffd60a66)" : "";
    const vtype = (node.value?.type || "").slice(0,4);
    nodes+=`<g>
      <circle cx="${cx}" cy="${cy}" r="${NW/2}" fill="${fill}" stroke="${stroke}" stroke-width="${sw}" style="filter:${glow}"/>
      <text x="${cx}" y="${cy-3}" text-anchor="middle" fill="white" font-size="9" font-weight="700" font-family="monospace">${node.key}</text>
      <text x="${cx}" y="${cy+8}" text-anchor="middle" fill="rgba(255,255,255,.7)" font-size="7" font-family="monospace">${vtype}</text>
    </g>`;
    traverse(node.left); traverse(node.right);
  }
  traverse(pos);
  svg.innerHTML = edges + nodes;
}

// ── STATE UPDATES ──────────────────────────────────────────────
let activeThreats = {};

function updateStats(stats) {
  document.getElementById("s-queue").textContent = stats.inQueue;
  document.getElementById("s-res").textContent = stats.totalResolved;
  document.getElementById("s-height").textContent = stats.treeHeight;
  document.getElementById("s-bh").textContent = stats.blackHeight;
  document.getElementById("m-sc").textContent = stats.shortCircuits;
  document.getElementById("m-todo").textContent = stats.todoCount;
  document.getElementById("m-bc").textContent = stats.balanceCalls;
  document.getElementById("m-rot").textContent = stats.rotations;
  const pct = stats.balanceCalls > 0 ? Math.round((stats.shortCircuits/stats.balanceCalls)*100) : 0;
  document.getElementById("m-pct").textContent = pct + "%";
  document.getElementById("m-bar").style.width = pct + "%";
  // Header
  const cnt = stats.inQueue;

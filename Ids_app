RED, BLACK, DOUBLE_BLACK = "RED", "BLACK", "DOUBLE_BLACK"

@dataclass
class Node:
    key: int
    value: Any
    color: str
    left: Optional['Node'] = field(default=None, repr=False)
    right: Optional['Node'] = field(default=None, repr=False)
    nid: str = field(default_factory=lambda: str(uuid.uuid4())[:8])

    def to_dict(self):
        return {
            "key": self.key,
            "color": self.color,
            "nid": self.nid,
            "value": self.value,
            "left": self.left.to_dict() if self.left else None,
            "right": self.right.to_dict() if self.right else None,
        }

def is_red(n): return n is not None and n.color == RED
def is_black(n): return n is None or n.color == BLACK
def mk(color, left, key, value, right):
    return Node(key=key, value=value, color=color, left=left, right=right)

# ═══════════════════════════════════════════════════════════════
# ALGORITHM 1: OKASAKI (Section 2 of paper)
# Classic 4-case balance, no short-circuit
# ═══════════════════════════════════════════════════════════════

class OkasakiTree:
    name = "Okasaki"
    rotations = 0
    balance_calls = 0

    def __init__(self):
        self.root = None
        self.rotations = 0
        self.balance_calls = 0

    def _balance(self, color, left, key, value, right):
        self.balance_calls += 1
        # All 4 cases from the paper
        if color == BLACK and is_red(left) and is_red(left.left):
            a, x, vx = left.left.left, left.left.key, left.left.value
            b, y, vy = left.left.right, left.key, left.value
            c, z, vz = left.right, key, value
            d = right
            self.rotations += 1
            return mk(RED, mk(BLACK,a,x,vx,b), y, vy, mk(BLACK,c,z,vz,d))
        if color == BLACK and is_red(left) and is_red(left.right):
            a, x, vx = left.left, left.key, left.value
            b, y, vy = left.right.left, left.right.key, left.right.value
            c, z, vz = left.right.right, key, value
            d = right
            self.rotations += 1
            return mk(RED, mk(BLACK,a,x,vx,b), y, vy, mk(BLACK,c,z,vz,d))
        if color == BLACK and is_red(right) and is_red(right.left):
            a, x, vx = left, key, value
            b, y, vy = right.left.left, right.left.key, right.left.value
            c, z, vz = right.left.right, right.key, right.value
            d = right.right
            self.rotations += 1
            return mk(RED, mk(BLACK,a,x,vx,b), y, vy, mk(BLACK,c,z,vz,d))
        if color == BLACK and is_red(right) and is_red(right.right):
            a, x, vx = left, key, value
            b, y, vy = right.left, right.key, right.value
            c, z, vz = right.right.left, right.right.key, right.right.value
            d = right.right.right
            self.rotations += 1
            return mk(RED, mk(BLACK,a,x,vx,b), y, vy, mk(BLACK,c,z,vz,d))
        return mk(color, left, key, value, right)

    def _ins(self, node, key, value):
        if node is None:
            return mk(RED, None, key, value, None)
        if key < node.key:
            return self._balance(node.color, self._ins(node.left, key, value), node.key, node.value, node.right)
        elif key > node.key:
            return self._balance(node.color, node.left, node.key, node.value, self._ins(node.right, key, value))
        else:
            return node

    def insert(self, key, value):
        r = self._ins(self.root, key, value)
        self.root = mk(BLACK, r.left, r.key, r.value, r.right)

    def delete(self, key):
        self.root, _ = self._delete(self.root, key)
        if self.root:
            self.root.color = BLACK

    def _delete(self, node, key):
        if node is None:
            return None, False
        if key < node.key:
            new_left, removed = self._delete(node.left, key)
            new_node = mk(node.color, new_left, node.key, node.value, node.right)
            return self._fix_delete(new_node, removed, 'left'), removed
        elif key > node.key:
            new_right, removed = self._delete(node.right, key)
            new_node = mk(node.color, node.left, node.key, node.value, new_right)
            return self._fix_delete(new_node, removed, 'right'), removed
        else:
            return self._remove_node(node)

    def _remove_node(self, node):
        if node.left is None and node.right is None:
            return None, node.color == BLACK
        if node.left is None:
            if node.color == RED:
                return node.right, False
            elif is_red(node.right):
                return mk(BLACK, node.right.left, node.right.key, node.right.value, node.right.right), False
            return node.right, True
        if node.right is None:
            if node.color == RED:
                return node.left, False
            elif is_red(node.left):
                return mk(BLACK, node.left.left, node.left.key, node.left.value, node.left.right), False
            return node.left, True
        succ_key, succ_val = self._min_node(node.right)
        new_right, short = self._delete_min(node.right)
        new_node = mk(node.color, node.left, succ_key, succ_val, new_right)
        return self._fix_delete(new_node, short, 'right'), False

    def _min_node(self, node):
        while node.left: node = node.left
        return node.key, node.value

    def _delete_min(self, node):
        if node.left is None:
            if node.color == RED: return None, False
            if is_red(node.right):
                return mk(BLACK, node.right.left, node.right.key, node.right.value, node.right.right), False
            return None, True
        new_left, short = self._delete_min(node.left)
        new_node = mk(node.color, new_left, node.key, node.value, node.right)
        return self._fix_delete(new_node, short, 'left'), False

    def _fix_delete(self, node, short, side):
        if not short or node is None: return node
        if side == 'left':
            sib = node.right
            if is_red(sib):
                new_root = mk(RED, node.left, node.key, node.value, sib.left)
                fixed, _ = self._fix_delete(new_root, True, 'left'), False
                return mk(BLACK, fixed, sib.key, sib.value, sib.right)
            if sib and is_black(sib.left) and is_black(sib.right):
                return mk(node.color, node.left, node.key, node.value, mk(RED, sib.left, sib.key, sib.value, sib.right))
        return node

    def search(self, key):
        n = self.root
        while n:
            if key == n.key: return n.value
            n = n.left if key < n.key else n.right
        return None

    def count(self):
        def _c(n): return 0 if n is None else 1 + _c(n.left) + _c(n.right)
        return _c(self.root)

# ═══════════════════════════════════════════════════════════════
# ALGORITHM 2: MOY MONADIC (Section 3 of paper)
# Result monad: D = done, T = todo (short-circuit)
# ═══════════════════════════════════════════════════════════════

class MonadicTree:
    name = "Monadic (Moy)"

    def __init__(self):
        self.root = None
        self.rotations = 0
        self.balance_calls = 0
        self.short_circuits = 0   # D results — work stopped early
        self.todo_calls = 0       # T results — work continues

    # Result monad: (is_todo: bool, tree)
    def _done(self, tree): return (False, tree)   # D constructor
    def _todo(self, tree): return (True,  tree)   # T constructor

    def _fmap(self, f, result):
        is_todo, tree = result
        return (is_todo, f(tree))

    def _bind(self, result, f):
        is_todo, tree = result
        if not is_todo:
            self.short_circuits += 1
            return result   # D: short-circuit, propagate done
        return f(tree)      # T: continue balancing

    def _balance(self, color, left, key, value, right):
        self.balance_calls += 1
        n = mk(color, left, key, value, right)
        # Case 1: left-left red
        if color==BLACK and is_red(left) and left and is_red(left.left):
            a,x,vx = left.left.left, left.left.key, left.left.value
            b,y,vy = left.left.right, left.key, left.value
            c,z,vz = left.right, key, value
            d = right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        # Case 2: left-right red
        if color==BLACK and is_red(left) and left and is_red(left.right):
            a,x,vx = left.left, left.key, left.value
            b,y,vy = left.right.left, left.right.key, left.right.value
            c,z,vz = left.right.right, key, value
            d = right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        # Case 3: right-left red
        if color==BLACK and is_red(right) and right and is_red(right.left):
            a,x,vx = left, key, value
            b,y,vy = right.left.left, right.left.key, right.left.value
            c,z,vz = right.left.right, right.key, right.value
            d = right.right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        # Case 4: right-right red
        if color==BLACK and is_red(right) and right and is_red(right.right):
            a,x,vx = left, key, value
            b,y,vy = right.left, right.key, right.value
            c,z,vz = right.right.left, right.right.key, right.right.value
            d = right.right.right
            self.rotations += 1
            return self._todo(mk(RED, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        # Black node — work is DONE (D constructor = short-circuit)
        if color == BLACK:
            self.short_circuits += 1
            return self._done(mk(BLACK, left, key, value, right))
        # Red node — may need more work (T constructor)
        self.todo_calls += 1
        return self._todo(mk(RED, left, key, value, right))

    def _ins(self, node, key, value):
        if node is None:
            return self._todo(mk(RED, None, key, value, None))
        if key < node.key:
            result = self._ins(node.left, key, value)
            new_result = self._fmap(lambda a: mk(node.color, a, node.key, node.value, node.right), result)
            return self._bind(new_result, lambda t: self._balance(t.color, t.left, t.key, t.value, t.right))
        elif key > node.key:
            result = self._ins(node.right, key, value)
            new_result = self._fmap(lambda b: mk(node.color, node.left, node.key, node.value, b), result)
            return self._bind(new_result, lambda t: self._balance(t.color, t.left, t.key, t.value, t.right))
        else:
            return self._done(node)

    def insert(self, key, value):
        _, r = self._ins(self.root, key, value)
        if r: self.root = mk(BLACK, r.left, r.key, r.value, r.right)
        else: self.root = r

    # Deletion using balance' + eqL + eqR (Section 4 of paper)
    def _blacken_prime(self, node):
        """blacken' from paper"""
        if node and is_red(node):
            return self._done(mk(BLACK, node.left, node.key, node.value, node.right))
        return self._todo(node)

    def _balance_prime(self, node):
        """balance' from Section 4.1 — resolves violations AND increases black height"""
        self.balance_calls += 1
        if node is None: return self._blacken_prime(node)
        k, left, key, value, right = node.color, node.left, node.key, node.value, node.right
        # Same 4 cases but preserves root color and returns D
        if is_red(left) and left and is_red(left.left):
            a,x,vx = left.left.left, left.left.key, left.left.value
            b,y,vy = left.left.right, left.key, left.value
            c,z,vz = left.right, key, value
            d = right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if is_red(left) and left and is_red(left.right):
            a,x,vx = left.left, left.key, left.value
            b,y,vy = left.right.left, left.right.key, left.right.value
            c,z,vz = left.right.right, key, value
            d = right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if is_red(right) and right and is_red(right.left):
            a,x,vx = left, key, value
            b,y,vy = right.left.left, right.left.key, right.left.value
            c,z,vz = right.left.right, right.key, right.value
            d = right.right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        if is_red(right) and right and is_red(right.right):
            a,x,vx = left, key, value
            b,y,vy = right.left, right.key, right.value
            c,z,vz = right.right.left, right.right.key, right.right.value
            d = right.right.right
            self.rotations += 1
            return self._done(mk(k, mk(BLACK,a,x,vx,b), y,vy, mk(BLACK,c,z,vz,d)))
        return self._blacken_prime(node)

    def _eqL(self, node):
        """eqL from Section 4.2 — left child is short"""
        if node is None: return self._todo(node)
        k, a, x, vx, sib = node.color, node.left, node.key, node.value, node.right
        if sib is None: return self._todo(node)
        if sib.color == BLACK:
            # Redden sibling, apply balance'
            new_sib = mk(RED, sib.left, sib.key, sib.value, sib.right)
            return self._balance_prime(mk(k, a, x, vx, new_sib))
        else:
            # Red sibling: rotate and recurse
            b, y, vy, c = sib.left, sib.key, sib.value, sib.right
            inner = mk(RED, a, x, vx, b)
            result = self._eqL(inner)
            return self._fmap(lambda new_a: mk(BLACK, new_a, y, vy, c), result)

    def _eqR(self, node):
        """eqR from Section 4.2 — right child is short"""
        if node is None: return self._todo(node)
        k, sib, y, vy, c = node.color, node.left, node.key, node.value, node.right
        if sib is None: return self._todo(node)
        if sib.color == BLACK:
            new_sib = mk(RED, sib.left, sib.key, sib.value, sib.right)
            return self._balance_prime(mk(k, new_sib, y, vy, c))
        else:
            a, x, vx, b = sib.left, sib.key, sib.value, sib.right
            inner = mk(RED, b, y, vy, c)
            result = self._eqR(inner)
            return self._fmap(lambda new_b: mk(BLACK, a, x, vx, new_b), result)

    def _del_min(self, node):
        """delMin from Section 4.3"""
        if node is None: return self._done(None), None
        if node.left is None:
            min_key, min_val = node.key, node.value
            if is_red(node): return self._done(node.right), (min_key, min_val)
            return self._blacken_prime(node.right), (min_key, min_val)
        result, min_kv = self._del_min(node.left)
        new_result = self._fmap(lambda a: mk(node.color, a, node.key, node.value, node.right), result)
        return self._bind(new_result, self._eqL), min_kv

    def _del_cur(self, node):
        """delCur from Section 4.3"""
        if node is None: return self._done(None)
        if is_red(node) and node.right is None: return self._done(node.left)
        if not is_red(node) and node.right is None: return self._blacken_prime(node.left)
        b_result, min_kv = self._del_min(node.right)
        if min_kv is None: return self._done(node.left)
        min_key, min_val = min_kv
        new_result = self._fmap(lambda b: mk(node.color, node.left, min_key, min_val, b), b_result)
        return self._bind(new_result, self._eqR)

    def _del(self, node, key):
        """delete from Section 4.3"""
        if node is None: return self._done(None)
        if key < node.key:
            result = self._del(node.left, key)
            new_result = self._fmap(lambda a: mk(node.color, a, node.key, node.value, node.right), result)
            return self._bind(new_result, self._eqL)
        elif key > node.key:
            result = self._del(node.right, key)
            new_result = self._fmap(lambda b: mk(node.color, node.left, node.key, node.value, b), result)
            return self._bind(new_result, self._eqR)
        else:
            return self._del_cur(node)

    def delete(self, key):
        _, r = self._del(self.root, key)
        self.root = r
        if self.root: self.root.color = BLACK

    def search(self, key):
        n = self.root
        while n:
            if key == n.key: return n.value
            n = n.left if key < n.key else n.right
        return None

    def count(self):
        def _c(n): return 0 if n is None else 1 + _c(n.left) + _c(n.right)
        return _c(self.root)

